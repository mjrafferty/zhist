# vim:ft=zsh

__zhist_insert_query() {
  local query
  integer pipe_fd

  query="${1}"

  exec {pipe_fd} <> "${__ZHIST_PIPE}"

  if [[ -n "${pipe_fd}" ]]; then
    if [[ "$ZHIST_ENABLE_LOG" == 1 ]]; then
      echo "${query}" >&"${pipe_fd}" >>! "${ZHIST_QUERY_LOG:-$__ZHIST_DEFAULT_QUERY_LOG}"
    else
      echo "${query}" >&"${pipe_fd}"
    fi
    exec {pipe_fd}>&-
  fi
}

__zhist_insert_query "$@"
